{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "permission": {},
  "references": {
    "effect": {
      "repository": "github.com/Effect-TS/effect-smol",
      "description": "Use for Effect v4 and effect-smol implementation details",
    },
    "cipher-local": {
      "path": "~/.local/share/cipher",
      "description": "Contains cipher logs and data",
    },
  },
  "skills": {
    "cli-coding-agents": {
      "path": "./skills/cli-coding-agents/skill.json",
      "description": "CLI-based coding agents and terminal-native development"
    },
    "ai-coding-tools": {
      "path": "./skills/ai-coding-tools/skill.json",
      "description": "AI-powered development tools, IDEs, and code assistants"
    },
    "ai-ides-assistants": {
      "path": "./skills/ai-ides-assistants/skill.json",
      "description": "AI assistants in IDEs and editor environments"
    },
    "ai-models-providers": {
      "path": "./skills/ai-models-providers/skill.json",
      "description": "AI models, LLM providers, and model orchestration"
    },
    "devops-cloud-ai": {
      "path": "./skills/devops-cloud-ai/skill.json",
      "description": "AI-powered DevOps, infrastructure, and CI/CD"
    },
    "code-review-quality": {
      "path": "./skills/code-review-quality/skill.json",
      "description": "AI code review, static analysis, quality gates"
    },
    "database-backend-ai": {
      "path": "./skills/database-backend-ai/skill.json",
      "description": "AI for database design, backend, and API creation"
    },
    "frontend-ui-ai": {
      "path": "./skills/frontend-ui-ai/skill.json",
      "description": "AI-powered frontend and UI/UX generation"
    },
    "security-testing-ai": {
      "path": "./skills/security-testing-ai/skill.json",
      "description": "AI security auditing, testing, and QA"
    },
    "local-privacy-ai": {
      "path": "./skills/local-privacy-ai/skill.json",
      "description": "Local-first, privacy-preserving AI coding tools"
    },
    "multi-agent-orchestration": {
      "path": "./skills/multi-agent-orchestration/skill.json",
      "description": "Multi-agent orchestration and agent teams"
    },
    "vim-neovim-ai": {
      "path": "./skills/vim-neovim-ai/skill.json",
      "description": "AI integration for Vim and Neovim"
    },
    "agent-skills-development": {
      "path": "./skills/agent-skills-development/skill.json",
      "description": "Creating and distributing custom agent skills"
    },
    "effect": {
      "path": "./skills/effect/SKILL.md",
      "description": "Effect v4 and effect-smol implementation"
    }
  },
  "agents": {
    "registry": "./agents/registry.json",
    "available": [
